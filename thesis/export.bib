   year = {2019}
}
@article{Chesney2009,
   abstract = {We explore the scientific potential of virtual worlds for experimental economics in terms of the subject pools and experimental platforms they present. Our results offer tentative, qualified support for virtual world experimentation. Overall, the behaviour of virtual subjects recruited, incentivised and observed within Second Life across a range of five standard experimental games was not found to differ significantly from established standard results. In addition, we identify certain methodological opportunities and challenges which confront virtual world experimenters. © 2009 Elsevier B.V. All rights reserved.},
