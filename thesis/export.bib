@article{Pashchenko2025,
   abstract = {The shift to Web3 heralds a decentralized Internet, prompting a reevaluation of centralized crypto exchanges over control concerns. Decentralized exchanges, leveraging blockchain, offer autonomous asset management, reducing risks and broadening access. Automated market makers (AMMs) drive decentralization by ensuring liquidity and stable pricing sans order books. Traditional banking faces challenges in asset divisibility and transparency, while blockchain tech, smart contracts, and NFTs streamline securities issuance by segmenting assets for auditability, transforming finance. In asset-backed securitization on blockchain, institutions link assets and securities directly via matrix representation. Smart contracts enable NFT-based security issuance, allowing secure transactions and holdings for investors. NFT ABS enhances audit traceability and investor fungibility, paving the way for commodity DEX platforms specializing in token pair exchange. These platforms feature fees in fungible tokens only, safeguarding assets from manipulation and ensuring user privacy. Our DEX project adopts Uniswap v1 for its innovative design and DeFi impact. Uniswap v1's formula ensures liquidity and trades without order books, enhancing security through Ethereum smart contracts. Integrating REST API with Swagger boosts usability, aiding developer comprehension and cross-platform integration. The AMM model incentivizes liquidity providers through fees, strengthening pools for enhanced functionality and user engagement.},
   author = {Yaroslav Pashchenko and Nikita Azhazha and Gennady Marin and Vyacheslav Davydov and Yury Yanovich},
   doi = {10.1145/3708622.3708628},
   isbn = {9798400717390},
   journal = {ICBTA 2024 - 2024 7th International Conference on Blockchain Technology and Applications},
   month = {1},
   pages = {26-35},
   publisher = {Association for Computing Machinery, Inc},
   title = {Decentralized Commodity Exchange},
   url = {/doi/pdf/10.1145/3708622.3708628?download=true},
   year = {2025}
}
@article{Kim2022,
   abstract = {Decentralized Finance (DeFi) is an emerging financial service model based on blockchain technology. DeFi composability denotes the ability for different DeFi services to interact with one another resulting in new forms of financial services. The DeFi ecosystem is largely based on ERC-20 tokens that can represent the value of an asset. Collateralized assets in DeFi composability are locked and additional profit cannot be generated. In this paper, we propose a method to generate profit from locked assets by using ERC-721 Non-Fungible Tokens (NFTs) and perpetual contracts. NFT represents the rights to a certain asset. A perpetual contract is a futures contract that does not have an expiration date. We propose perpetual contract NFT, a new form of NFT that can be used as collateral, which exploits perpetual futures contracts in the cryptocurrency derivatives market. Collateral needs to be provided to back the value of a perpetual contract. If the perpetual contract is minted as NFT, the resulting NFT represents the rights to the perpetual contract and its collateral. Therefore, the perpetual contact NFT itself can be used as collateral for DeFi composability. A proof-of-concept smart contract and a web application for perpetual contract NFT are provided to demonstrate its functionality. To validate the profitability of the perpetual contract NFT using a real-world scenario, we experiment with the position NFT of Uniswap v3 decentralized exchange. The position NFT is a form of perpetual contract NFT. Specifically, we present validation with three types of pools: stablecoins, stablecoin/wrapped tokens pair, and wrapped tokens.},
   author = {Hyoungsung Kim and Hyun Sik Kim and Yong Suk Park},
   doi = {10.1109/ACCESS.2022.3225884},
   issn = {21693536},
   journal = {IEEE Access},
   keywords = {Automated market maker (AMM),Ethereum,blockchain,decentralized exchange (DEX),decentralized finance (DeFi),liquidity pool (LP),non-fungible token (NFT),uniswap},
   pages = {126802-126814},
   publisher = {Institute of Electrical and Electronics Engineers Inc.},
   title = {Perpetual Contract NFT as Collateral for DeFi Composability},
   volume = {10},
   year = {2022}
}
@article{Elsts2021,
   abstract = {Uniswap is the largest decentralized exchange (DEX) and one of cornerstones of Decentralized Finance (DeFi). Uniswap uses liquidity pools to provide Automated Market Making (AMM) functionality. Uniswap v3 is the most recent version of the protocol that introduces a number of new features, notably the concentrated liquidity feature, which allows the liquidity providers to concentrate their liquidity in a speciﬁc price range, leading to an increased capital efﬁciency. However, the mathematical relationship between the liquidity of a position, the amount of assets in that position, and its price range becomes somewhat complex. This technical note shows how derive some of the results from the Uniswap v3 whitepaper, as well as presents several other equations not discussed in the whitepaper, and shows how to apply these equations.},
   author = {Atis Elsts},
   doi = {10.2139/SSRN.4575232},
   journal = {SSRN Electronic Journal},
   keywords = {Atis Elsts,Automated Market Making,Concentrated Liquidity,Decentralised Finance,Liquidity Math in Uniswap v3,SSRN,Smart Contracts},
