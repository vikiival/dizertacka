issn = {15674223},
journal = {Electronic Commerce Research and Applications},
keywords = {Customer satisfaction,Hedonic shopping value,Information quality,Internet shopping,Repurchase intention,Service quality,System quality,Utilitarian shopping value},
month = {jul},
